{
  "base_url": "http://127.0.0.1:8080",
  "default_headers": {
    "content-type": "application/json"
  },
  "auth": {
    "type": "dev_jwt",
    "secret_env": "JWT_SECRET",
    "roles": ["admin"],
    "permissions": ["*:*"],
    "attributes": {
      "tenant_tier": "team",
      "workspace": "smoke-p4",
      "tenant_quotas": {
        "requests_per_minute": 600
      }
    }
  },
  "steps": [
    {
      "name": "create_code_repository",
      "method": "POST",
      "path": "/api/v1/code-repos/repositories",
      "expected_status": 200,
      "body": {
        "name": "P4 Smoke Repo ${RUN_ID}",
        "slug": "p4-smoke-repo-${RUN_ID}",
        "description": "P4 developer platform smoke repository",
        "owner": "Platform UI",
        "default_branch": "main",
        "visibility": "private",
        "object_store_backend": "local",
        "package_kind": "widget",
        "tags": ["smoke", "p4"],
        "settings": {
          "runtime": "rust"
        }
      },
      "capture": {
        "repository_id": "/id"
      }
    },
    {
      "name": "create_feature_branch",
      "method": "POST",
      "path": "/api/v1/code-repos/repositories/${repository_id}/branches",
      "expected_status": 200,
      "body": {
        "name": "feature/p4-${RUN_ID}",
        "base_branch": "main",
        "protected": false
      },
      "capture": {
        "branch_name": "/name"
      },
      "expect": [
        {
          "path": "/base_branch",
          "equals": "main"
        }
      ]
    },
    {
      "name": "create_real_git_commit",
      "method": "POST",
      "path": "/api/v1/code-repos/repositories/${repository_id}/commits",
      "expected_status": 200,
      "body": {
        "branch_name": "${branch_name}",
        "title": "Add runtime helper",
        "description": "Adds a real tracked file for P4 smoke.",
        "author_name": "Platform UI",
        "files": [
          {
            "path": "src/runtime.rs",
            "content": "pub fn runtime_ready() -> bool {\n    true\n}\n",
            "delete": false
          }
        ]
      },
      "capture": {
        "commit_sha": "/sha"
      },
      "expect": [
        {
          "path": "/branch_name",
          "equals": "${branch_name}"
        },
        {
          "path": "/files_changed",
          "equals": 1
        }
      ]
    },
    {
      "name": "list_repository_commits",
      "method": "GET",
      "path": "/api/v1/code-repos/repositories/${repository_id}/commits",
      "expected_status": 200,
      "expect": [
        {
          "path": "/items/0/sha",
          "equals": "${commit_sha}"
        }
      ]
    },
    {
      "name": "search_repository_files",
      "method": "GET",
      "path": "/api/v1/code-repos/repositories/${repository_id}/search?q=package_kind",
      "expected_status": 200,
      "expect": [
        {
          "path": "/results/0/path",
          "equals": "src/lib.rs"
        }
      ]
    },
    {
      "name": "diff_feature_branch",
      "method": "GET",
      "path": "/api/v1/code-repos/repositories/${repository_id}/diff?branch=${branch_name}",
      "expected_status": 200,
      "expect": [
        {
          "path": "/patch",
          "exists": true
        }
      ]
    },
    {
      "name": "trigger_real_ci_run",
      "method": "POST",
      "path": "/api/v1/code-repos/repositories/${repository_id}/ci",
      "expected_status": 200,
      "body": {
        "branch_name": "${branch_name}"
      },
      "expect": [
        {
          "path": "/status",
          "equals": "passed"
        },
        {
          "path": "/checks/0",
          "exists": true
        }
      ]
    },
    {
      "name": "install_marketplace_app_template",
      "method": "POST",
      "path": "/api/v1/marketplace/installs",
      "expected_status": 200,
      "body": {
        "listing_id": "01968b70-4f20-71b8-a6f0-0f4000001001",
        "version": "1.0.0",
        "workspace_name": "P4 Smoke ${RUN_ID}"
      },
      "capture": {
        "installed_app_slug": "/activation/resource_slug"
      },
      "expect": [
        {
          "path": "/activation/kind",
          "equals": "app_template"
        },
        {
          "path": "/activation/status",
          "equals": "activated"
        },
        {
          "path": "/activation/public_url",
          "exists": true
        }
      ]
    },
    {
      "name": "load_published_marketplace_app",
      "method": "GET",
      "path": "/api/v1/apps/public/${installed_app_slug}",
      "expected_status": 200,
      "expect": [
        {
          "path": "/app/slug",
          "equals": "${installed_app_slug}"
        },
        {
          "path": "/published_version_number",
          "equals": 1
        }
      ]
    }
  ]
}
